{
  "name": "arcos-shell",
  "version": "0.7.0",
  "description": "ArcOS Desktop Shell — bootable Linux desktop",
  "main": "electron/main.js",
  "scripts": {
    "start":        "electron .",
    "dev":          "NODE_ENV=development electron .",
    "build:linux":  "electron-builder --linux AppImage --x64",
    "build:win":    "electron-builder --win nsis --x64",
    "build":        "npm run build:linux"
  },
  "keywords": ["desktop","shell","linux","wayland","electron"],
  "author": "ArcOS Project",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.arcos.shell",
    "productName": "ArcOS",
    "artifactName": "ArcOS-${version}-${arch}.${ext}",
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "System",
      "executableName": "arcos-shell"
    },
    "win": { "target": ["nsis"] },
    "directories": { "output": "dist" },
    "files": ["index.html","css/**","js/**","electron/**","assets/**"],
    "asar": true
  }
}
